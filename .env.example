# Required by NCBI Entrez (https://www.ncbi.nlm.nih.gov/books/NBK25497/)
NCBI_EMAIL=your_email@example.com
# Optional: higher rate limits
# NCBI_API_KEY=

# Ollama (local LLM on Mac — uses Metal)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
# Pull first: ollama pull qwen2.5:7b  (or qwen2.5:14b if you have RAM). Alternatives: llama3.1:8b, llama3.3.
# Synthesis temperature (ask/workflow). 0.0 recommended for stable, literal summaries.
# OLLAMA_TEMPERATURE=0.0

# Embeddings (HuggingFace id, runs locally). After changing: ingest.py --reset
# Recommended for PubMed title+abstract chunks: SPECTER (paper similarity)
# EMBEDDING_MODEL=sentence-transformers/allenai-specter
# Lighter default:
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Paths (relative to project root or absolute)
DATA_DIR=data
CHROMA_COLLECTION=pubmed_chunks

# Ingest default when you omit --max-papers (thousands-scale; set lower for a quick test)
# DEFAULT_INGEST_MAX_PAPERS=2500

# RAG: BM25 + dense (RRF) → cross-encoder rerank (re-ingest with --reset after retrieval upgrades)
# USE_HYBRID_RETRIEVAL=true
# USE_CROSS_ENCODER_RERANK=true
# RRF_K=60
# RETRIEVAL_TOP_K=40
# RERANK_TOP_K=12
# CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# KG: entity expansion (shared entity → extra triples from other PMIDs)
# GRAPH_EXPAND_ENTITIES=true
# GRAPH_EXPAND_MAX_EXTRA_TRIPLES=80
