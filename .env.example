# Copy to .env and edit. Do not commit .env.

# Required for PubMed download (https://www.ncbi.nlm.nih.gov/books/NBK25497/)
NCBI_EMAIL=your_email@example.com
# NCBI_API_KEY=

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_TEMPERATURE=0.0

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

DATA_DIR=data
CHROMA_COLLECTION=pubmed_chunks

# DEFAULT_INGEST_MAX_PAPERS=2500
# USE_HYBRID_RETRIEVAL=true
# RRF_K=60
# RETRIEVAL_TOP_K=40
# RERANK_TOP_K=12
# CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# GRAPH_EXPAND_ENTITIES=true
# GRAPH_EXPAND_MAX_EXTRA_TRIPLES=80
